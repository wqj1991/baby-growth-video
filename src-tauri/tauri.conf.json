{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:8092",
    "frontendDist": "../dist"
  },
  "productName": "宝宝成长视频",
  "version": "0.1.0",
  "identifier": "com.baby.growth.video",
  "app": {
    "windows": [
      {
        "title": "宝宝成长视频",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "PhotoVideo",
    "shortDescription": "宝宝成长视频制作工具",
    "longDescription": "制作宝宝成长视频的桌面应用，按周期整理照片，生成精美成长视频。",
    "copyright": "© 2024 Baby Growth Video"
  },
  "plugins": {}
}