{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "core:dialog:allow-open",
    "core:dialog:allow-save",
    "core:fs:allow-read-file",
    "core:fs:allow-write-file",
    "core:fs:allow-read-dir",
    "core:fs:allow-create-dir",
    "core:fs:allow-remove-file",
    "core:path:allow-basename",
    "core:path:allow-dirname",
    "core:path:allow-join",
    "core:path:allow-resolve",
    "core:path:allow-normalize",
    "core:shell:allow-open"
  ]
}
